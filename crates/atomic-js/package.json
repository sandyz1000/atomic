{
  "name": "@atomic-compute/js",
  "version": "0.1.0",
  "description": "Spark-like distributed RDD API for Node.js and TypeScript, backed by the Atomic Rust engine via napi-rs",
  "main": "dist/index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "napi build --platform --release --no-js --manifest-path ../../Cargo.toml && tsc",
    "build:debug": "napi build --platform --no-js --manifest-path ../../Cargo.toml && tsc",
    "prepare": "tsc",
    "type-check": "tsc --project tsconfig.typecheck.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2",
    "@types/node": "^25.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "compute",
    "distributed",
    "napi",
    "rdd",
    "spark",
    "typescript",
    "map-reduce",
    "dataframe",
    "parallel"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sandip-dey/atomic"
  }
}
